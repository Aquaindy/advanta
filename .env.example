APP_NAME=AdVanta AI
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=replace-with-secure-secret
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://advanta:advanta@localhost:5432/advanta_ai
# Optional — separate database for backend tests. If unset, tests fall back to DATABASE_URL with `_test` suffix.
TEST_DATABASE_URL=postgresql+psycopg://advanta:advanta@localhost:5432/advanta_ai_test
REDIS_URL=redis://localhost:6379/0

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-key

# LLM provider selection. Supported: "openai" (default), "anthropic", "google_ai".
# Workspaces can override per-call with a BYOK credential under Settings → API keys.
LLM_PROVIDER=openai

# OpenAI — GPT-5.4 mini is the default (fast, agentic; supports tools + skills).
OPENAI_API_KEY=
LLM_MODEL=gpt-5.4-mini

# Anthropic Claude (recommended). Pick one:
#   claude-opus-4-7   — most capable, highest cost
#   claude-sonnet-4-6 — balanced default (used here)
#   claude-haiku-4-5-20251001 — fastest / cheapest
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google AI (Gemini)
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-1.5-flash

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

META_APP_ID=
META_APP_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Frontend (apps/web) — Vite reads VITE_-prefixed vars
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=AdVanta AI
