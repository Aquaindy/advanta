APP_NAME=AdVanta
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=replace-with-secure-secret
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://advanta:advanta@localhost:5432/advanta_ai
# Optional — separate database for backend tests. If unset, tests fall back to DATABASE_URL with `_test` suffix.
TEST_DATABASE_URL=postgresql+psycopg://advanta:advanta@localhost:5432/advanta_ai_test
REDIS_URL=redis://localhost:6379/0

# Local dev origins. Production (getadvanta.app) is set in the Render blueprint:
#   CORS_ORIGINS=["https://getadvanta.app","https://www.getadvanta.app"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-key

# LLM provider selection. Supported: "openai" (default), "anthropic", "google_ai".
# Workspaces can override per-call with a BYOK credential under Settings → API keys.
LLM_PROVIDER=openai

# OpenAI — GPT-5.4 mini is the default (fast, agentic; supports tools + skills).
OPENAI_API_KEY=
LLM_MODEL=gpt-5.4-mini
# Optional faster/cheaper model used ONLY for the large Growth DNA background
# generation (must match the active provider, e.g. claude-haiku-4-5 / gpt-5.4-mini).
LLM_FAST_MODEL=

# Anthropic Claude (recommended). Pick one:
#   claude-opus-4-7   — most capable, highest cost
#   claude-sonnet-4-6 — balanced default (used here)
#   claude-haiku-4-5-20251001 — fastest / cheapest
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google AI (Gemini)
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-1.5-flash

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

META_APP_ID=
META_APP_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Recurring subscription billing ---------------------------------------
# Two processors are supported for the AdVanta plans. Paddle takes precedence
# when configured (Merchant of Record — handles global sales tax/VAT); Stripe
# is the fallback. Configure ONE.

# Stripe (recurring) — leave blank to use Paddle instead.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=

# Paddle (recurring, Merchant of Record). Subscriptions activate once
# PADDLE_API_KEY + PADDLE_WEBHOOK_SECRET are set; checkout uses the client-side
# overlay (PADDLE_CLIENT_TOKEN). Webhook endpoint: /api/v1/billing/paddle/webhook
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
# "sandbox" while testing, "production" when live.
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRICE_ID_STARTER=
PADDLE_PRICE_ID_PRO=
PADDLE_PRICE_ID_AGENCY=

# --- Fee-collection layer (optional, one-off ad-management fees) -----------
# Separate from subscriptions above. The fee ledger is processor-agnostic; set
# any of these to enable that processor for billing accrued platform fees.
# Stripe reuses STRIPE_SECRET_KEY. "manual" needs no config.
# Paddle fees reuse PADDLE_API_KEY above.
# Point at sandbox while testing: https://sandbox-api.paddle.com
PADDLE_API_BASE=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Point at sandbox while testing: https://api-m.sandbox.paypal.com
PAYPAL_API_BASE=

# Public URLs. Production (getadvanta.app), set in the Render blueprint:
#   FRONTEND_URL=https://getadvanta.app
#   BACKEND_URL=https://api.getadvanta.app
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Frontend (apps/web) — Vite reads VITE_-prefixed vars at BUILD time.
# Production: VITE_API_BASE_URL=https://api.getadvanta.app/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=AdVanta

# ---------------------------------------------------------------------------
# Operational / optional (mostly production). All safe to leave blank locally.
# ---------------------------------------------------------------------------

# Background jobs. 1 = dispatch slow work (agent runs, SMTP sends, autopilot
# scans) to the Celery worker; 0 = run inline in the request. Production = 1.
WORKERS_ENABLED=0
# Override only if the broker/result backend should differ from REDIS_URL.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Transactional email (invites, reports, outreach). Read via os.getenv; if
# SMTP_HOST is blank, emails are logged and dropped (no send).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@getadvanta.app
SMTP_TLS=1

# Inbound email parsing for outreach replies (reply+<token>@<domain>).
INBOUND_EMAIL_DOMAIN=
INBOUND_EMAIL_SECRET=

# Website Agent — Google PageSpeed Insights key (raises the PSI rate limit).
PAGESPEED_API_KEY=

# Error monitoring. No-op when blank.
SENTRY_DSN=
